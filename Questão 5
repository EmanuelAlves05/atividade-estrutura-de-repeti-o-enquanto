programa {
  funcao inicio() {
    
    real contador = 1, nota = 0, media, soma=0
    
    enquanto(contador<=4){
      escreva("Qual a sua nota?\n")
      leia(nota)

      soma = soma + nota  
      media = soma / 4 
      contador = contador + 1

    }
    escreva("A media final é\n", media)
}
}
